		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1",
		"tailwind-merge": "^3.5.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"openapi-typescript": "^7.13.0",
